NODE_ENV=development
PORT=4000

# Either set DATABASE_URL, or the PG* vars below
DATABASE_URL=postgres://postgres:postgres@localhost:5432/price_app
DATABASE_SSL=false

PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=price_app

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h

CORS_ORIGIN=http://localhost:5173
