NODE_ENV=development
PORT=4000

# Either set DATABASE_URL, or the PG* vars below
DATABASE_URL=postgres://postgres:postgres@localhost:5432/price_app
DATABASE_SSL=false

PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=price_app

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h

CORS_ORIGIN=http://localhost:5173

# URL of the frontend (used to build links in outgoing emails)
APP_URL=http://localhost:5173

# Email (SMTP). Works with SendGrid, Postmark, Resend, SES, Gmail, etc.
# If SMTP_HOST is empty, emails are logged to the API console instead.
#   SendGrid:  smtp.sendgrid.net / 587 / user=apikey / pass=<API key>
#   Postmark:  smtp.postmarkapp.com / 587 / user=<token> / pass=<token>
#   Resend:    smtp.resend.com / 587 / user=resend / pass=<API key>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FROM=no-reply@labb.net
EMAIL_FROM_NAME=Labb Pricing
